# Database path (relative to working dir or absolute)
DB_PATH="data/yt-hunter.db"

# OpenAI-compatible API (OpenAI, Ollama, etc.)
# For the bundled Ollama container use: http://ollama:11434/v1
# For a local Ollama instance use:          http://localhost:11434/v1
OPENAI_BASE_URL="http://ollama:11434/v1"
OPENAI_MODEL="gemma4:12b"
OPENAI_API_KEY=""

# YouTube channels to track (comma-separated handles)
CHANNELS="TheCarbonLayer"

# Signal notifications (optional)
# Use "http://signal-cli-rest-api:8080" inside Docker Compose, or the host URL locally.
SIGNAL_SERVER="http://signal-cli-rest-api:8080"
SIGNAL_SERVER_NUMBER="+1234567890"
SIGNAL_RECEPIENT="+0987654321"
